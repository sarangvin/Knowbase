# Postgres connection string
DATABASE_URL=postgres://user:password@localhost:5432/knowbase

# Google Cloud Console → APIs & Services → Credentials → OAuth client (Web application)
# Authorized redirect URI must exactly match GOOGLE_REDIRECT_URI below.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8787/auth/google/callback

# Comma-separated emails that get role='owner' on first sign-in (admin access,
# global vault write access). Only checked when a user row doesn't exist yet.
OWNER_EMAILS=you@example.com

# Where to redirect back to after login (the frontend origin)
APP_URL=http://localhost:5173

# CORS allowlist — exact origins only, comma-separated. In local dev with the
# Vite proxy (see vite.config.ts) this can stay empty since requests become
# same-origin; set it once frontend and backend are deployed separately.
CORS_ORIGINS=http://localhost:5173

PORT=8787
NODE_ENV=development

# 32-byte key, base64-encoded, for encrypting BYO LLM API keys at rest.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
API_KEY_ENCRYPTION_KEY=

# Your own Gemini API key (aistudio.google.com/apikey) — powers the free
# default tier (a real hosted Gemma model, via Google's Generative Language
# API), never exposed to any client. Rate-limited per user.
# NOTE: this used to be Groq, but Groq dropped every Gemma model from their
# catalog. GEMINI_MODEL is optional (defaults to gemma-3-27b-it) — override
# it here, no code change needed, if Google renames/deprecates that model.
GEMINI_API_KEY=
GEMINI_MODEL=

# Your own Anthropic key — powers the paid "pro" tier's better model.
ANTHROPIC_API_KEY=

# Razorpay (dashboard.razorpay.com → Settings → API Keys). RAZORPAY_PLAN_ID is
# a Plan you create once in the dashboard (Subscriptions → Plans) for the Pro
# tier's monthly price. RAZORPAY_WEBHOOK_SECRET is set when you add the
# webhook URL (https://<your-api-domain>/api/billing/webhook) under
# Settings → Webhooks — enable subscription.activated/charged/cancelled/
# completed/expired events. Google Pay appears automatically in Razorpay's
# Checkout for supported devices — no separate integration needed.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_PLAN_ID=
RAZORPAY_WEBHOOK_SECRET=
